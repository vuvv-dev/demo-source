# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Ví dụ: postgresql://postgres:password@localhost:5432/apple_store
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/apple_store

# Authentication
JWT_SECRET=z
JWT_EXPIRES_IN=7d

# PayOS Configuration (Payment Gateway)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# URL Configuration
# Frontend URL dùng cho CORS và Redirect sau khi thanh toán
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# VietQR.io Configuration (Chuyển khoản ngân hàng - VietQR)
# Cú pháp: https://img.vietqr.io/image/[BANK_CODE]-[ACCOUNT]-compact.png?amount=...&addInfo=...
# Bank code: VCB, TPB, MBB, ACB, VTB... (tra tại https://vietqr.io)
VIETQR_BANK_CODE=VCB
VIETQR_ACCOUNT_NUMBER=1029990197

# Payment Redirect URLs 
PAYMENT_RETURN_URL=http://localhost:3000/order-success
PAYMENT_CANCEL_URL=http://localhost:3000/order-failed

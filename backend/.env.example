# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Ví dụ: postgresql://postgres:password@localhost:5432/apple_store
DATABASE_URL=postgresql://postgres:password@localhost:5432/apple_store

# Authentication
# Điền một chuỗi bí mật bất kỳ
JWT_SECRET=zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz
JWT_EXPIRES_IN=7d

# PayOS Configuration (Payment Gateway)
# Lấy các thông tin này từ dashboard.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# URL Configuration
# Frontend URL dùng cho CORS và Redirect sau khi thanh toán
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Payment Redirect URLs (Thanh toán xong/hủy sẽ quay về đây)
PAYMENT_RETURN_URL=http://localhost:3000/order-success
PAYMENT_CANCEL_URL=http://localhost:3000/order-failed
